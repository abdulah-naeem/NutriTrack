# ========================
# NutriTrack — Environment Variables
# ========================
# Copy this file to .env and fill in your keys.
# All keys are FREE to obtain. Links below.

# --- Supabase (Auth + Database) ---
# Create free project: https://supabase.com/dashboard
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Nutrition APIs ---
# CalorieNinjas (10K req/month): https://calorieninjas.com/api
CALORIENINJAS_API_KEY=your_calorieninjas_api_key_here

# USDA FoodData Central (unlimited): https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here

# --- AI APIs ---
# Groq (fast LLM inference): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini (Google AI): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here